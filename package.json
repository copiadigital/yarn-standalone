{
  "name": "yarn-standalone",
  "version": "1.0.0",
  "description": "Standalone Yarn executable like wp-cli.phar",
  "main": "src/cli.js",
  "bin": {
    "yarn-standalone": "./src/cli.js"
  },
  "scripts": {
    "build": "pkg . --output dist/yarn --targets node22-linux-x64,node22-linux-arm64 --compress GZip",
    "build:all": "pkg . --output dist/yarn --targets node22-linux-x64,node22-linux-arm64,node22-macos-x64,node22-win-x64 --compress GZip"
  },
  "pkg": {
    "scripts": "src/**/*.js",
    "assets": [
      "yarn-bundle/**/*"
    ],
    "targets": [
      "node22-linux-x64",
      "node22-linux-arm64"
    ],
    "outputPath": "dist"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2"
  }
}
